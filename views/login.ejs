<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Lora:ital,wght@0,400..700;1,400..700&family=Manrope:wght@200..800&family=Vend+Sans:ital,wght@0,300..700;1,300..700&family=Zalando+Sans+SemiExpanded:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
</head>
  
<body class="bg-[#ECF0F6]">
    <div class="w-screen h-screen flex flex-row items-center justify-center font-[Zalando_Sans_SemiExpanded]">
        <form action="/login" method="POST" class="lg:w-1/3 w-7/8 bg-white py-8 rounded-lg px-8 ">
            <h1 class="text-[#1F8CF9] text-center font-extrabold text-3xl tracking-tight">Library Admin</h1>
            <p class="mt-4 text-lg font-semibold tracking-tight text-center font-[DM_Sans]">Welcome Back</p>
            <p class="text-center lg:text-sm text-xs text-[#626877] font-[DM_Sans]">Enter your credentials to manage the library</p>
            <div class="flex flex-col mt-8"> 
                <label for="workEmail" class="text-sm font-semibold">Email:</label>
                <div class="flex flex-row border-2 px-2 py-2 text-sm border-[#DCE0E5] items-center rounded-lg mt-2 gap-2">
                    <img src="./images/letter.png" class="h-4" alt="">
                    <input name="email" type="text" placeholder="admin@library.com" class="focus:outline-none font-[DM_Sans] text-sm w-full" name="" id="workEmail">
                </div>
            </div>
            <div class="flex flex-col mt-6"> 
                <label for="password" class="text-sm font-semibold">Password:</label>
                <div class="flex flex-row border-2 px-2 py-2 text-sm border-[#DCE0E5] items-center rounded-lg mt-2 gap-2">
                    <img src="./images/lock.png" class="h-4" alt="">
                    <input name="password" type="password" placeholder="••••••••" class="focus:outline-none font-[DM_Sans] text-sm w-full" name="" id="password">
                </div>
            </div>
            <p name="error" class="mt-6 text-sm text-red-500 font-[DM_Sans]"><%= error %></p>
            <button class="text-white bg-blue-600 hover:bg-blue-700 py-2 items-center flex mt-2 w-full justify-center text-sm hover:cursor-pointer font-semibold rounded m-auto">Sign In <svg class="h-8" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#E0E0E0" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"><line x1="60" y1="100" x2="130" y2="100" /><polyline points="110,75 140,100 110,125" /></g></svg></button>
        </form>
    </div>
</body>
</html>